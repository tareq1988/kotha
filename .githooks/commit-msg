#!/bin/sh
# Validate commit messages against Conventional Commits. See CONTRIBUTING.md.
# Enabled via: git config core.hooksPath .githooks
header=$(head -n1 "$1")

# Let merge / revert / fixup / squash commits through untouched.
case "$header" in
    "Merge "*|"Revert "*|fixup!*|squash!*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?!?: .+'
if printf '%s' "$header" | grep -Eq "$pattern"; then
    exit 0
fi

cat >&2 <<EOF
✗ Commit message is not a valid Conventional Commit.

  Format:  <type>(<optional scope>): <description>
  Types:   feat fix docs style refactor perf test build ci chore revert
  Example: feat(hotkeys): let users choose the trigger modifier key

  First line was:
    $header
EOF
exit 1
